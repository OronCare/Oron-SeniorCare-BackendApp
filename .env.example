# Database Configuration for Sequelize
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=oron_db
NODE_ENV=development

# AES-256-GCM resident data encryption (any strong secret; hashed with SHA-256 before use)
ENCRYPTION_KEY=

# OneSignal (push) — create an app at https://onesignal.com and use Web + REST API key
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# When true, disables browser push (use in-app notifications only).
DISABLE_BROWSER_NOTIFICATIONS=true
